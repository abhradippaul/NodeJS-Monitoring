@baseUrl = http://localhost:3000

### Health Check
GET {{baseUrl}}/health

### Info Endpoint
GET {{baseUrl}}/info

### Metrics (Prometheus)
GET {{baseUrl}}/metrics

### Slow Request (Simulation)
GET {{baseUrl}}/slow?duration=1000

### --- Item CRUD Operations ---

### Create Item
# @name createItem
POST {{baseUrl}}/items
Content-Type: application/json

{
    "name": "Sample Item",
    "quantity": 10,
    "price": 29.99
}

### Get All Items
GET {{baseUrl}}/items

### Get Items with Orders
GET {{baseUrl}}/items/with-orders

### Get Item with Orders (Specific)
@itemId = {{createItem.response.body.data._id}}
GET {{baseUrl}}/items/{{itemId}}/orders

### Update Item
PUT {{baseUrl}}/items/{{itemId}}
Content-Type: application/json

{
    "name": "Updated Sample Item",
    "quantity": 15,
    "price": 34.99
}

### Delete Item
DELETE {{baseUrl}}/items/{{itemId}}


### --- Order CRUD Operations ---

### Create Order
# @name createOrder
POST {{baseUrl}}/orders
Content-Type: application/json

{
    "items": [
        {
            "item": "{{itemId}}",
            "quantity": 2
        }
    ]
}

### Get All Orders
GET {{baseUrl}}/orders

### Get Order by ID
@orderId = {{createOrder.response.body.data._id}}
GET {{baseUrl}}/orders/{{orderId}}
